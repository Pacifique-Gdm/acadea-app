{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/((?!api/|src/|@vite/|@react-refresh|@fs/|node_modules/|assets/|icons/|manifest.webmanifest|sw.js|version.json|favicon.svg|favicon.png).*)",
      "destination": "/index.html"
    }
  ]
}
