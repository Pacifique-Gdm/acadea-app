rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function tenantSchoolId() {
      return request.auth.token.schoolId;
    }

    function tenantParentId() {
      return request.auth.token.parentId;
    }

    function superAdmin() {
      return signedIn() && role() == "super_admin";
    }

    function schoolUser() {
      return signedIn()
        && role() in ["school_admin", "cashier", "parent"]
        && tenantSchoolId() is string;
    }

    function schoolAdmin() {
      return signedIn() && role() == "school_admin" && tenantSchoolId() is string;
    }

    function parentUser() {
      return signedIn()
        && role() == "parent"
        && tenantSchoolId() is string
        && tenantParentId() is string;
    }

    function sameTenantResource() {
      return schoolUser() && resource.data.schoolId == tenantSchoolId();
    }

    function sameTenantCreate() {
      return schoolUser()
        && request.resource.data.schoolId is string
        && request.resource.data.schoolId == tenantSchoolId();
    }

    function sameTenantUpdate() {
      return sameTenantResource()
        && request.resource.data.schoolId == resource.data.schoolId;
    }

    function sameYearUpdate() {
      return !("schoolYearId" in resource.data)
        || request.resource.data.schoolYearId == resource.data.schoolYearId;
    }

    match /platform/appConfig {
      allow read: if true;
      allow write: if superAdmin();
    }

    match /platform/{document=**} {
      allow read, write: if superAdmin();
    }

    match /schools/{schoolId} {
      allow read: if superAdmin() || (schoolUser() && schoolId == tenantSchoolId());
      allow create, update: if superAdmin();
      allow delete: if superAdmin();
    }

    match /users/{userId} {
      allow read: if superAdmin() || (signedIn() && request.auth.uid == userId);
      allow create: if (superAdmin()
          && request.resource.data.id == userId
          && request.resource.data.role == "school_admin"
          && request.resource.data.schoolId is string)
        || (schoolAdmin()
          && request.resource.data.id == userId
          && request.resource.data.role == "parent"
          && request.resource.data.schoolId == tenantSchoolId()
          && request.resource.data.parentId is string);
      allow update: if signedIn()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["id", "role", "schoolId", "parentId", "studentIds", "status"]);
      allow delete: if false;
    }

    match /schoolYears/{yearId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if false;
    }

    match /students/{studentId} {
      allow read: if superAdmin()
        || (role() in ["school_admin", "cashier"] && sameTenantResource())
        || (parentUser() && resource.data.schoolId == tenantSchoolId() && resource.data.parentId == tenantParentId());
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if false;
    }

    match /parents/{parentId} {
      allow read: if superAdmin()
        || (role() in ["school_admin", "cashier"] && sameTenantResource())
        || (parentUser() && resource.data.schoolId == tenantSchoolId() && parentId == tenantParentId());
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /payments/{paymentId} {
      allow read: if superAdmin()
        || (role() in ["school_admin", "cashier"] && sameTenantResource())
        || (parentUser() && resource.data.schoolId == tenantSchoolId() && resource.data.parentId == tenantParentId());
      allow create: if signedIn()
        && role() == "cashier"
        && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /expenses/{expenseId} {
      allow read: if superAdmin() || role() in ["school_admin", "cashier"] && sameTenantResource();
      allow create: if signedIn()
        && role() == "cashier"
        && sameTenantCreate();
      allow update, delete: if schoolAdmin() && sameTenantResource();
    }

    match /auditLogs/{auditLogId} {
      allow read: if superAdmin() || schoolAdmin() && sameTenantResource();
      allow create: if signedIn()
        && role() in ["school_admin", "cashier"]
        && sameTenantCreate();
      allow update, delete: if false;
    }

    match /feeTypes/{feeTypeId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /teachers/{teacherId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /classes/{classId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /grades/{gradeId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /attendance/{attendanceId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /bulletins/{bulletinId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /documents/{documentId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /announcements/{announcementId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /valves/{valveId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /messages/{messageId} {
      allow read: if superAdmin()
        || (role() in ["school_admin", "cashier"] && sameTenantResource())
        || (parentUser() && resource.data.schoolId == tenantSchoolId() && resource.data.threadParentId == tenantParentId());
      allow create: if (signedIn()
          && role() in ["school_admin", "cashier"]
          && sameTenantCreate())
        || (parentUser()
          && request.resource.data.schoolId == tenantSchoolId()
          && request.resource.data.threadParentId == tenantParentId()
          && request.resource.data.recipientParentId == "school");
      allow update, delete: if schoolAdmin() && sameTenantResource();
    }

    match /notifications/{notificationId} {
      allow read: if superAdmin()
        || (role() in ["school_admin", "cashier"] && sameTenantResource())
        || (parentUser() && resource.data.schoolId == tenantSchoolId() && resource.data.parentId == tenantParentId());
      allow create: if signedIn()
        && role() in ["school_admin", "cashier"]
        && sameTenantCreate()
        || (parentUser()
          && request.resource.data.schoolId == tenantSchoolId()
          && request.resource.data.recipientRole == "school"
          && request.resource.data.type == "message");
      allow update: if (role() in ["school_admin", "cashier"] && sameTenantUpdate())
        || (parentUser()
        && resource.data.schoolId == tenantSchoolId()
        && resource.data.parentId == tenantParentId()
        && request.resource.data.parentId == resource.data.parentId
        && request.resource.data.schoolId == resource.data.schoolId);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
