rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function tenantSchoolId() {
      return request.auth.token.schoolId;
    }

    function tenantParentId() {
      return request.auth.token.parentId;
    }

    function superAdmin() {
      return signedIn() && role() == "super_admin";
    }

    function billingControlsShape() {
      return request.resource.data.keys().hasOnly(["valvesUploadsEnabled", "reason", "updatedAt", "updatedBy"])
        && request.resource.data.valvesUploadsEnabled is bool
        && request.resource.data.updatedAt is string
        && (!("reason" in request.resource.data) || request.resource.data.reason is string)
        && (!("updatedBy" in request.resource.data) || request.resource.data.updatedBy is string);
    }

    function schoolUser() {
      return signedIn()
        && role() in ["school_admin", "cashier", "parent"]
        && tenantSchoolId() is string;
    }

    function schoolAdmin() {
      return signedIn() && role() == "school_admin" && tenantSchoolId() is string;
    }

    function parentUser() {
      return signedIn()
        && role() == "parent"
        && tenantSchoolId() is string
        && tenantParentId() is string;
    }

    function disciplineDirector() {
      return signedIn()
        && role() == "discipline_director"
        && tenantSchoolId() is string;
    }

    function sameTenantResource() {
      return schoolUser() && resource.data.schoolId == tenantSchoolId();
    }

    function sameTenantCreate() {
      return schoolUser()
        && request.resource.data.schoolId is string
        && request.resource.data.schoolId == tenantSchoolId();
    }

    function disciplineTenantResource() {
      return disciplineDirector() && resource.data.schoolId == tenantSchoolId();
    }

    function disciplineTenantCreate() {
      return disciplineDirector()
        && request.resource.data.schoolId is string
        && request.resource.data.schoolId == tenantSchoolId();
    }

    function sameTenantUpdate() {
      return sameTenantResource()
        && request.resource.data.schoolId == resource.data.schoolId;
    }

    function sameYearUpdate() {
      return !("schoolYearId" in resource.data)
        || request.resource.data.schoolYearId == resource.data.schoolYearId;
    }

    function schoolSettingsUpdate(schoolId) {
      return schoolAdmin()
        && schoolId == tenantSchoolId()
        && request.resource.data.id == resource.data.id
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "name",
          "motto",
          "address",
          "phone",
          "email",
          "logoUrl",
          "acronym",
          "educationLevels",
          "schoolOptions",
          "schoolType",
          "activeSchoolYearId",
          "updatedAt",
          "updatedBy"
        ]);
    }

    match /platform/appConfig {
      allow read: if true;
      allow write: if superAdmin();
    }

    match /platform/{document=**} {
      allow read, write: if superAdmin();
    }

    match /platformSettings/billingControls {
      allow read: if signedIn();
      allow create, update: if superAdmin() && billingControlsShape();
      allow delete: if false;
    }

    match /schools/{schoolId} {
      allow read: if superAdmin() || (schoolUser() && schoolId == tenantSchoolId()) || (disciplineDirector() && schoolId == tenantSchoolId());
      allow create: if superAdmin();
      allow update: if superAdmin() || schoolSettingsUpdate(schoolId);
      allow delete: if superAdmin();
    }

    match /users/{userId} {
      allow read: if superAdmin() || (signedIn() && request.auth.uid == userId);
      allow create: if (superAdmin()
          && request.resource.data.id == userId
          && request.resource.data.role == "school_admin"
          && request.resource.data.schoolId is string)
        || (schoolAdmin()
          && request.resource.data.id == userId
          && request.resource.data.role == "parent"
          && request.resource.data.schoolId == tenantSchoolId()
          && request.resource.data.parentId is string);
      allow update: if signedIn()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["id", "role", "schoolId", "parentId", "studentIds", "status"]);
      allow delete: if false;
    }

    match /schoolYears/{yearId} {
      allow read: if superAdmin() || sameTenantResource() || disciplineTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if false;
    }

    match /students/{studentId} {
      allow read: if superAdmin()
        || (role() in ["school_admin", "cashier"] && sameTenantResource())
        || disciplineTenantResource()
        || (parentUser() && resource.data.schoolId == tenantSchoolId() && resource.data.parentId == tenantParentId());
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if false;
    }

    match /parents/{parentId} {
      allow read: if superAdmin()
        || (role() in ["school_admin", "cashier"] && sameTenantResource())
        || disciplineTenantResource()
        || (parentUser() && resource.data.schoolId == tenantSchoolId() && parentId == tenantParentId());
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /payments/{paymentId} {
      allow read: if superAdmin()
        || (role() in ["school_admin", "cashier"] && sameTenantResource())
        || (parentUser() && resource.data.schoolId == tenantSchoolId() && resource.data.parentId == tenantParentId());
      allow create: if signedIn()
        && role() == "cashier"
        && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /expenses/{expenseId} {
      allow read: if superAdmin() || role() in ["school_admin", "cashier"] && sameTenantResource();
      allow create: if signedIn()
        && role() == "cashier"
        && sameTenantCreate();
      allow update, delete: if schoolAdmin() && sameTenantResource();
    }

    match /auditLogs/{auditLogId} {
      allow read: if superAdmin() || schoolAdmin() && sameTenantResource();
      allow create: if signedIn()
        && ((role() in ["school_admin", "cashier"] && sameTenantCreate())
          || disciplineTenantCreate());
      allow update, delete: if false;
    }

    match /disciplineSanctions/{sanctionId} {
      allow read: if superAdmin()
        || (schoolAdmin() && sameTenantResource())
        || disciplineTenantResource();
      allow create: if disciplineTenantCreate()
        && request.resource.data.schoolId is string
        && request.resource.data.schoolId.size() > 0
        && request.resource.data.schoolYearId is string
        && request.resource.data.schoolYearId.size() > 0
        && request.resource.data.studentId is string
        && request.resource.data.studentId.size() > 0
        && request.resource.data.studentName is string
        && request.resource.data.studentName.size() > 0
        && request.resource.data.className is string
        && request.resource.data.className.size() > 0
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.sanctionType is string
        && request.resource.data.sanctionType.size() > 0
        && (request.resource.data.duration is int || request.resource.data.duration is float)
        && request.resource.data.duration > 0
        && request.resource.data.startDate is string
        && request.resource.data.startDate.size() > 0
        && request.resource.data.expectedEndDate is string
        && request.resource.data.expectedEndDate.size() > 0
        && request.resource.data.status == "active"
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdBy is string
        && request.resource.data.createdBy.size() > 0
        && request.resource.data.createdAt is string
        && request.resource.data.createdAt.size() > 0;
      allow update: if disciplineTenantResource()
        && resource.data.status == "active"
        && request.resource.data.status == "completed"
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.schoolYearId == resource.data.schoolYearId
        && request.resource.data.studentId == resource.data.studentId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
    }

    match /feeTypes/{feeTypeId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /teachers/{teacherId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /classes/{classId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /grades/{gradeId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /attendance/{attendanceId} {
      allow read: if superAdmin()
        || sameTenantResource()
        || disciplineTenantResource();
      allow create: if (schoolAdmin() && sameTenantCreate())
        || (
          disciplineTenantCreate()
          && request.resource.data.schoolYearId is string
          && request.resource.data.schoolYearId.size() > 0
        );
      allow update: if (schoolAdmin() && sameTenantUpdate() && sameYearUpdate())
        || (
          disciplineTenantResource()
          && request.resource.data.schoolId == resource.data.schoolId
          && request.resource.data.schoolYearId == resource.data.schoolYearId
        );
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /bulletins/{bulletinId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /documents/{documentId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /announcements/{announcementId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /valves/{valveId} {
      allow read: if superAdmin() || sameTenantResource();
      allow create: if schoolAdmin() && sameTenantCreate();
      allow update: if schoolAdmin() && sameTenantUpdate() && sameYearUpdate();
      allow delete: if schoolAdmin() && sameTenantResource();
    }

    match /messages/{messageId} {
      allow read: if superAdmin()
        || (role() in ["school_admin", "cashier"] && sameTenantResource())
        || (disciplineTenantResource() && resource.data.schoolRecipient == "discipline")
        || (parentUser() && resource.data.schoolId == tenantSchoolId() && resource.data.threadParentId == tenantParentId());
      allow create: if (signedIn()
          && role() in ["school_admin", "cashier"]
          && sameTenantCreate())
        || (disciplineTenantCreate()
          && request.resource.data.schoolRecipient == "discipline");
      allow update, delete: if schoolAdmin() && sameTenantResource();
    }

    match /conversations/{conversationId} {
      allow read: if superAdmin()
        || (schoolAdmin() && sameTenantResource() && resource.data.schoolRecipient in ["admin", "both"])
        || (signedIn() && role() == "cashier" && sameTenantResource() && resource.data.schoolRecipient in ["cashier", "both"])
        || (disciplineTenantResource() && resource.data.schoolRecipient == "discipline")
        || (parentUser() && resource.data.schoolId == tenantSchoolId() && resource.data.parentId == tenantParentId());
      allow create: if (schoolAdmin()
          && sameTenantCreate()
          && request.resource.data.schoolRecipient == "admin")
        || (signedIn()
          && role() == "cashier"
          && sameTenantCreate()
          && request.resource.data.schoolRecipient == "cashier")
        || (disciplineTenantCreate()
          && request.resource.data.schoolRecipient == "discipline");
      allow update: if (schoolAdmin()
          && sameTenantUpdate()
          && resource.data.schoolRecipient in ["admin", "both"]
          && request.resource.data.schoolId == resource.data.schoolId
          && request.resource.data.schoolYearId == resource.data.schoolYearId
          && request.resource.data.parentId == resource.data.parentId
          && request.resource.data.threadId == resource.data.threadId
          && request.resource.data.threadParentId == resource.data.threadParentId
          && request.resource.data.schoolRecipient == resource.data.schoolRecipient)
        || (signedIn()
          && role() == "cashier"
          && sameTenantUpdate()
          && resource.data.schoolRecipient in ["cashier", "both"]
          && request.resource.data.schoolId == resource.data.schoolId
          && request.resource.data.schoolYearId == resource.data.schoolYearId
          && request.resource.data.parentId == resource.data.parentId
          && request.resource.data.threadId == resource.data.threadId
          && request.resource.data.threadParentId == resource.data.threadParentId
          && request.resource.data.schoolRecipient == resource.data.schoolRecipient)
        || (disciplineDirector()
          && disciplineTenantResource()
          && request.resource.data.schoolId == resource.data.schoolId
          && request.resource.data.schoolYearId == resource.data.schoolYearId
          && request.resource.data.parentId == resource.data.parentId
          && request.resource.data.threadId == resource.data.threadId
          && request.resource.data.threadParentId == resource.data.threadParentId
          && request.resource.data.schoolRecipient == resource.data.schoolRecipient
          && resource.data.schoolRecipient == "discipline")
        || (parentUser()
          && resource.data.schoolId == tenantSchoolId()
          && resource.data.parentId == tenantParentId()
          && request.resource.data.schoolId == resource.data.schoolId
          && request.resource.data.schoolYearId == resource.data.schoolYearId
          && request.resource.data.parentId == resource.data.parentId
          && request.resource.data.threadId == resource.data.threadId
          && request.resource.data.threadParentId == resource.data.threadParentId
          && request.resource.data.schoolRecipient == resource.data.schoolRecipient);
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if superAdmin()
        || (role() in ["school_admin", "cashier"] && sameTenantResource())
        || (disciplineTenantResource() && resource.data.recipientRole == "school" && resource.data.schoolRecipient == "discipline")
        || (parentUser() && resource.data.schoolId == tenantSchoolId() && resource.data.parentId == tenantParentId());
      allow create: if signedIn()
        && ((role() in ["school_admin", "cashier"] && sameTenantCreate())
          || (disciplineTenantCreate()
            && ((request.resource.data.recipientRole == "school" && request.resource.data.schoolRecipient == "discipline")
              || (request.resource.data.recipientRole == "parent" && request.resource.data.parentId is string))));
      allow update: if (role() in ["school_admin", "cashier"] && sameTenantUpdate())
        || (disciplineDirector()
          && disciplineTenantResource()
          && resource.data.schoolRecipient == "discipline"
          && request.resource.data.schoolId == resource.data.schoolId
          && request.resource.data.schoolYearId == resource.data.schoolYearId
          && request.resource.data.schoolRecipient == resource.data.schoolRecipient)
        || (parentUser()
        && resource.data.schoolId == tenantSchoolId()
        && resource.data.parentId == tenantParentId()
        && request.resource.data.parentId == resource.data.parentId
        && request.resource.data.schoolId == resource.data.schoolId);
      allow delete: if false;
    }

    match /messageIdempotency/{schoolId}/signals/{signalId} {
      allow get: if disciplineDirector() && schoolId == tenantSchoolId();
      allow list: if false;
      allow create: if disciplineDirector()
        && schoolId == tenantSchoolId()
        && request.resource.data.schoolId == tenantSchoolId()
        && request.resource.data.schoolYearId is string
        && request.resource.data.sanctionId is string
        && request.resource.data.messageId is string
        && request.resource.data.notificationId is string
        && request.resource.data.createdAt is string
        && request.resource.data.type == "discipline-sanction-signal"
        && request.resource.data.keys().hasOnly([
          "schoolId",
          "schoolYearId",
          "sanctionId",
          "messageId",
          "notificationId",
          "createdAt",
          "type"
        ]);
      allow update, delete: if false;
    }

    match /parentDailyMessageLimits/{limitId} {
      allow get: if parentUser()
        && resource.data.schoolId == tenantSchoolId()
        && resource.data.parentId == tenantParentId();
      allow list: if false;
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
